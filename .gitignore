# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.output/
.gatsby/
.cache/
.parcel-cache/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Generated files
*.min.js
*.min.css
*.bundle.js
*.chunk.js
*.map
*.js.map
*.css.map

# Assets cache
.asset-cache/
.cache/
.eslintcache
.stylelintcache

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
.tmp/
.temp/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn
*~

# Emacs
*~
\#*\#
.\#*

# Backup files
*.bak
*.backup
*.old
*.orig

# Images cache
images/.generated/
images/thumbnails/
images/optimized/

# Assets cache
assets/.cache/

# Service worker
sw.js
sw.js.map
service-worker.js
workbox-*.js

# PWA icons
icons/*.png
!icons/icon-192.png
!icons/icon-512.png
!icons/favicon.ico

# Screenshots
screenshots/
*.png
!favicon.png
!*.svg

# Storybook
storybook-static/
node_modules/.cache/storybook/

# Debug
debug.log
chrome-user-data/

# .env files
.env
.env.local
.env.production
.env.development

# Generated HTML from build
*.html
!index.html
!404.html
!*.html
!**/*.html

# Keep specific files
!.gitignore
!.keep
!.gitkeep